#include "config.hlsl"
#include "quaternions.hlsl"
#include "../reflect/types.hlsl"
#include "../reflect/structs.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    standard vertex transformation utility functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

//  return the position relative to the camera
float3 getInterpolatorRelative( in Camera camera, in float3 position )
{
    return( position - camera.locate.xyz );
}

//  transform the local position by the instance transform and return its position relative to the camera
float3 getInterpolatorRelative( in Camera camera, in Entity entity, in float3 position )
{
    return( fastRotateVector( ( position * entity.scale.xyz ), entity.rotate ) + ( entity.locate.xyz - camera.locate.xyz ) );
}

//  transform the camera relative position into view-space position
float3 getInterpolatorViewPos( in Camera camera, in float3 relative )
{
    return( fastInverseRotateVector( relative, camera.rotate ) );
}

//  apply the camera projection matrix to the view-space position
float4 getInterpolatorHClip( in Camera camera, in float3 viewpos )
{
    return( camera.project[ 3 ] + 
        ( camera.project[ 2 ] * viewpos.z ) +
        ( camera.project[ 1 ] * viewpos.y ) +
        ( camera.project[ 0 ] * viewpos.x ) );
}

//  pass-through normal unchanged
float3 getInterpolatorNormal( float3 normal )
{
    return( normal );
}

//  transform world-space normal into view-space
float3 getInterpolatorNormal( in Camera camera, in float3 normal )
{
    return( fastInverseRotateVector( normal, camera.rotate ) );
}

//  transform entity-space normal into world-space
float3 getInterpolatorNormal( in Entity entity, in float3 normal )
{
    return( fastRotateVector( normal, entity.rotate ) );
}

//  transform entity-space normal into view-space
float3 getInterpolatorNormal( in Camera camera, in Entity entity, in float3 normal )
{
    return( fastRotateVector( normal, qcmul( entity.rotate, camera.rotate ) ) );
}

//  pass-through tspace unchanged
float4 getInterpolatorTSpace( float4 tspace )
{
    return( tspace );
}

//  transform world-space tspace into view-space
float4 getInterpolatorTSpace( in Camera camera, in float4 tspace )
{
    return( fastInverseRotateTSpace( tspace, camera.rotate ) );
}

//  transform entity-space tspace into world-space
float4 getInterpolatorTSpace( in Entity entity, in float4 tspace )
{
    return( fastRotateTSpace( tspace, entity.rotate ) );
}

//  transform entity-space tspace into view-space
float4 getInterpolatorTSpace( in Camera camera, in Entity entity, in float4 tspace )
{
    return( fastRotateTSpace( tspace, qcmul( entity.rotate, camera.rotate ) ) );
}

