#include "utils.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    noise gradient selection functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float2 getPerlinGradient2D( in const float i )
{
    float t = frac( i * ( 255.0f / 256.0f ) );                                                                  //  rescale the input
    float2 gradient = ( ( floor( frac( t * float2( 1.0f, 2.0f ) ) * 2.0f ) * 2.0f ) - 1.0f );                   //  create vector { +/-1.0f, +/-1.0f }
    gradient *= saturate( abs( floor( frac( t * 16.0f ) * 4.0f ) - float2( 1.0f, 0.0f ) ) );                    //  kill 1 channel of 4 (the third and fourth channels are imaginary)
    return( normalize( gradient ) );
}

float2 getNoiseGradient2D( in const float i )
{
    float t = frac( i * ( 255.0f / 256.0f ) );                                                                  //  rescale the input
    float2 gradient = ( ( floor( frac( t * float2( 1.0f, 2.0f ) ) * 2.0f ) * 2.0f ) - 1.0f );                   //  create vector { +/-1.0f, +/-1.0f }
    gradient *= saturate( abs( floor( frac( t * 16.0f ) * 3.0f ) - float2( 1.0f, 0.0f ) ) );                    //  kill 1 channel of 3 (the third channel is imaginary)
    return( gradient );
}

float3 getNoiseGradient3D( in const float i )
{
    float t = frac( i * ( 255.0f / 256.0f ) );                                                                  //  rescale the input
    float3 gradient = ( ( floor( frac( t * float3( 1.0f, 2.0f, 4.0f ) ) * 2.0f ) * 2.0f ) - 1.0f );             //  create vector { +/-1.0f, +/-1.0f, +/-1.0f }
    gradient *= saturate( abs( floor( frac( t * 16.0f ) * 3.0f ) - float3( 2.0f, 1.0f, 0.0f ) ) );              //  kill 1 channel
    return( gradient );
}

float4 getNoiseGradient4D( in const float i )
{
    float t = frac( i * ( 255.0f / 256.0f ) );                                                                  //  rescale the input
    float4 gradient = ( ( floor( frac( t * float4( 1.0f, 2.0f, 4.0f, 8.0f ) ) * 2.0f ) * 2.0f ) - 1.0f );       //  create vector { +/-1.0f, +/-1.0f, +/-1.0f, +/-1.0f }
    gradient *= saturate( abs( floor( frac( t * 16.0f ) * 4.0f ) - float4( 3.0f, 2.0f, 1.0f, 0.0f ) ) );        //  kill 1 channel
    return( gradient );
}

