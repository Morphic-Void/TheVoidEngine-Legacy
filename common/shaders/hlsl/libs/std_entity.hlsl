#ifndef __STD_ENTITY_HLSL_INCLUDED__
#define __STD_ENTITY_HLSL_INCLUDED__

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    configuration notes:
////
////        ( STD_ENTITY_ENABLE == ENABLED )
////
////            declares the single object constant buffer 'Instance'
////            declares the simple std_getObject() function
////
////        ( STD_INSTANCE_ENABLE == ENABLED )
////
////            declares the instancing configuration constant buffer 'Instancing'
////            declares the multi-instance buffer 'instanceBuffer'
////            declares the instanced std_getObject( uint index ) function
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    includes
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "config.hlsl"
#include "../reflect/types.hlsl"
#include "../reflect/structs.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    disable undefined configurations
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#ifndef STD_ENTITY_ENABLE
#define STD_ENTITY_ENABLE   DISABLED
#endif

#ifndef STD_INSTANCE_ENABLE
#define STD_INSTANCE_ENABLE DISABLED
#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    begin entity enabled section
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#if ( STD_ENTITY_ENABLE == ENABLED )

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    single object instance constant buffer declaration
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#if ( STD_INSTANCE_ENABLE != ENABLED )

cbuffer cb_instance
{
    Entity      entity;
};

Entity std_getEntity()
{
    return( entity );
}

#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    simple multi-entity instancing buffer declarations
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#if ( STD_INSTANCE_ENABLE == ENABLED )

////    instanceConfig.x    :   first instance offset within the instance buffer
////    instanceConfig.y    :   instance stride within the instance buffer
////    instanceConfig.z    :   currently unused
////    instanceConfig.w    :   currently unused

cbuffer cb_Instancing
{
    uint4       instanceConfig;
};

Buffer<float4>  instanceBuffer;         //  instance data

Entity std_getEntity( in uint instance )
{
    Entity entity;
    uint index = ( instanceConfig.x + ( instance * instanceConfig.y ) );
    entity.scaling = instanceBuffer.Load( index + 0 );
    entity.quaternion = instanceBuffer.Load( index + 1 );
    entity.translation = instanceBuffer.Load( index + 2 );
    return( entity );
}

#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    end entity enabled section
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    end of include guard
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#endif  //  #ifndef __STD_ENTITY_HLSL_INCLUDED__

