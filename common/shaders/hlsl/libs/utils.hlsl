////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    min/max component functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float min( in float2 v ) { return( min( v.x, v.y ) ); };
float min( in float3 v ) { return( min( min( v.x, v.y ), v.z ) ); };
float min( in float4 v ) { float2 u = min( v.xy, v.zw ); return( min( u.x, u.y ) ); };
float max( in float2 v ) { return( max( v.x, v.y ) ); };
float max( in float3 v ) { return( max( max( v.x, v.y ), v.z ) ); };
float max( in float4 v ) { float2 u = max( v.xy, v.zw ); return( max( u.x, u.y ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    mid component function
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float mid( in float3 v ) { return( max( min( v.x, v.y ), min( max( v.x, v.y ), v.z ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    quantization functions
////
////    notes:
////
////        The steps value should be greater than 1, a value of 1 will cause a division by zero.
////        To quantize to 8-bit, steps should be 256.
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  quantize( in float  v, in float steps ) { return( saturate( floor( v * steps ) * rcp( steps - 1.0f ) ) ); };
float2 quantize( in float2 v, in float steps ) { return( saturate( floor( v * steps ) * rcp( steps - 1.0f ) ) ); };
float3 quantize( in float3 v, in float steps ) { return( saturate( floor( v * steps ) * rcp( steps - 1.0f ) ) ); };
float4 quantize( in float4 v, in float steps ) { return( saturate( floor( v * steps ) * rcp( steps - 1.0f ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    clamped root functions
////
////    notes:
////
////        The max() instruction ensures that negative inputs will return 0.0f as the root.
////        The abs() instruction ensures that the result of the max() instruction is not -0.0f.
////
////        The ieee floating point standard requires of -0.0f and 0.0f to be considered identical for
////        the purposes of comparison.
////
////        The max() function does not clearly define which of the 2 inputs is returned in cases
////        where they are identical.
////
////        Together these mean that either max( -0.0f, 0.0f ) or max( 0.0f, -0.0f ) instruction may return -0.0f.
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  safe_sqrt( in float  v ) { return( sqrt( abs( max( v, 0.0f ) ) ) ); };
float2 safe_sqrt( in float2 v ) { return( sqrt( abs( max( v, 0.0f ) ) ) ); };
float3 safe_sqrt( in float3 v ) { return( sqrt( abs( max( v, 0.0f ) ) ) ); };
float4 safe_sqrt( in float4 v ) { return( sqrt( abs( max( v, 0.0f ) ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    clamped reciprocal root functions
////
////    notes:
////
////        The clamping value of exp2( -44.0f ) or ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) was chosen by
////        experimentation on a Radeon GPU.
////
////        The clamping value is the smallest number that exhibited no artifacts during testing.
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  safe_rsqrt( in float  v ) { return( rsqrt( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float2 safe_rsqrt( in float2 v ) { return( rsqrt( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float3 safe_rsqrt( in float3 v ) { return( rsqrt( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float4 safe_rsqrt( in float4 v ) { return( rsqrt( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    clamped reciprocal functions
////
////    notes:
////
////        The clamping value is the same as that used for the safe_rsqrt() functions.
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  safe_rcp( in float  v ) { return( rcp( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float2 safe_rcp( in float2 v ) { return( rcp( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float3 safe_rcp( in float3 v ) { return( rcp( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };
float4 safe_rcp( in float4 v ) { return( rcp( max( v, ( 1.0f / ( 65536.0f * 65536.0f * 4096.0f ) ) ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    reciprocal length functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float rlen( in float2 v ) { return( rsqrt( dot( v, v ) ) ); };
float rlen( in float3 v ) { return( rsqrt( dot( v, v ) ) ); };
float rlen( in float4 v ) { return( rsqrt( dot( v, v ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    division by zero safe reciprocal length functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float safe_rlen( in float2 v ) { return( safe_rsqrt( dot( v, v ) ) ); };
float safe_rlen( in float3 v ) { return( safe_rsqrt( dot( v, v ) ) ); };
float safe_rlen( in float4 v ) { return( safe_rsqrt( dot( v, v ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    division by zero safe normalise functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float2 safe_normalize( in float2 v ) { return( v * safe_rlen( v ) ); };
float3 safe_normalize( in float3 v ) { return( v * safe_rlen( v ) ); };
float4 safe_normalize( in float4 v ) { return( v * safe_rlen( v ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    normal derivitive function
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 ddn( in float3 pos )
{
    return( normalize( cross( ddx( pos ), ddy( pos ) ) ) );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    division by zero safe normal derivitive function
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float3 safe_ddn( in float3 pos )
{
    return( safe_normalize( cross( ddx( pos ), ddy( pos ) ) ) );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    width derivitive functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  ddw( in float v )  { float  x = ddx( v ); float  y = ddy( v ); return( sqrt( ( x * x ) + ( y * y ) ) ); };
float2 ddw( in float2 v ) { float2 x = ddx( v ); float2 y = ddy( v ); return( sqrt( ( x * x ) + ( y * y ) ) ); };
float3 ddw( in float3 v ) { float3 x = ddx( v ); float3 y = ddy( v ); return( sqrt( ( x * x ) + ( y * y ) ) ); };
float4 ddw( in float4 v ) { float4 x = ddx( v ); float4 y = ddy( v ); return( sqrt( ( x * x ) + ( y * y ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    reciprocal width derivitive functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  rddw( in float v )  { float  x = ddx( v ); float  y = ddy( v ); return( rsqrt( ( x * x ) + ( y * y ) ) ); };
float2 rddw( in float2 v ) { float2 x = ddx( v ); float2 y = ddy( v ); return( rsqrt( ( x * x ) + ( y * y ) ) ); };
float3 rddw( in float3 v ) { float3 x = ddx( v ); float3 y = ddy( v ); return( rsqrt( ( x * x ) + ( y * y ) ) ); };
float4 rddw( in float4 v ) { float4 x = ddx( v ); float4 y = ddy( v ); return( rsqrt( ( x * x ) + ( y * y ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    division by zero safe reciprocal width derivitive functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float  safe_rddw( in float v )  { float  x = ddx( v ); float  y = ddy( v ); return( safe_rsqrt( ( x * x ) + ( y * y ) ) ); };
float2 safe_rddw( in float2 v ) { float2 x = ddx( v ); float2 y = ddy( v ); return( safe_rsqrt( ( x * x ) + ( y * y ) ) ); };
float3 safe_rddw( in float3 v ) { float3 x = ddx( v ); float3 y = ddy( v ); return( safe_rsqrt( ( x * x ) + ( y * y ) ) ); };
float4 safe_rddw( in float4 v ) { float4 x = ddx( v ); float4 y = ddy( v ); return( safe_rsqrt( ( x * x ) + ( y * y ) ) ); };

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    grid line calculation functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float getGrid( in float3 pos )
{
    float3 x = ddx( pos );
    float3 y = ddy( pos );
    float3 n = safe_normalize( cross( x, y ) );
    return( saturate( max( ( 1.0f - ( ( 0.5f - abs( 0.5f - frac( pos ) ) ) * safe_rsqrt( ( x * x ) + ( y * y ) ) ) ) * ( 1.0f - ( n * n ) ) ) ) );
}

float getGrid( in float3 pos, in float width )
{
    float3 x = ddx( pos );
    float3 y = ddy( pos );
    float3 n = safe_normalize( cross( x, y ) );
    return( saturate( max( ( width - ( ( 0.5f - abs( 0.5f - frac( pos ) ) ) * safe_rsqrt( ( x * x ) + ( y * y ) ) ) ) * ( 1.0f - ( n * n ) ) ) ) );
}

float getGrid( in float3 pos, in float3 scaling )
{
    return( getGrid( ( pos * scaling ) ) );
}

float getGrid( in float3 pos, in float3 scaling, in float width )
{
    return( getGrid( ( pos * scaling ), width ) );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    grid line calculation functions with an user defined normal
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float getGridWithNormal( in float3 pos, in float3 nrm )
{
    return( saturate( max( ( 1.0f - ( ( 0.5f - abs( 0.5f - frac( pos ) ) ) * safe_rddw( pos ) ) ) * ( 1.0f - ( nrm * nrm ) ) ) ) );
}

float getGridWithNormal( in float3 pos, in float3 nrm, in float width )
{
    return( saturate( max( ( width - ( ( 0.5f - abs( 0.5f - frac( pos ) ) ) * safe_rddw( pos ) ) ) * ( 1.0f - ( nrm * nrm ) ) ) ) );
}

float getGridWithNormal( in float3 pos, in float3 nrm, in float3 scaling )
{
    return( getGridWithNormal( ( pos * scaling ), nrm ) );
}

float getGridWithNormal( in float3 pos, in float3 nrm, in float3 scaling, in float width )
{
    return( getGridWithNormal( ( pos * scaling ), nrm, width ) );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    chequer board calculation functions
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float getChequer( in float3 pos )
{
    float3 xyz = saturate( ( ( abs( frac( ( pos - 0.5f ) * 0.5f ) - 0.5f ) * 2.0f ) - 0.5f ) * safe_rddw( pos ) );
    return( ( ( ( xyz.x * xyz.y * xyz.z * 2.0f ) - dot( xyz, xyz.yzx ) ) * 2.0f ) + xyz.x + xyz.y + xyz.z );
}

float getChequer( in float3 pos, in float width )
{
    float3 xyz = saturate( ( ( abs( frac( ( pos - 0.5f ) * 0.5f ) - 0.5f ) * 2.0f ) - 0.5f ) * safe_rddw( pos * width ) );
    return( ( ( ( xyz.x * xyz.y * xyz.z * 2.0f ) - dot( xyz, xyz.yzx ) ) * 2.0f ) + xyz.x + xyz.y + xyz.z );
}

float getChequer( in float3 pos, in float3 scaling )
{
    return( getChequer( pos * scaling ) );
}

float getChequer( in float3 pos, in float3 scaling, in float width )
{
    return( getChequer( ( pos * scaling ), width ) );
}

float getFastChequer( in float3 pos )
{
    return( frac( dot( ( pos - frac( pos ) ), 0.5f.xxx ) ) * 2.0f );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    outlining calculation functions
////
////    notes:
////
////        edgesT triangle edges opposite the vertex (edge normal distances pointing into the triangle)
////        edgesC outline edges clockwise from the vertex (line normal distances pointing into the triangle)
////        edgesA outline edges anti-clockwise from the vertex (line normal distances pointing into the triangle)
////
////        In general the edge distances should be world space distances, though other considerations can be used
////        to vary the thickness or positioning of the lines.
////
////        The thickness of lines produced by the getWorldOutline() functions and the position of lines produced by
////        the getInsetOutline() functions is primarily controlled by the scaling of the edge distances supplied to
////        the shader.
////
////        The getOutline() functions are not directly affected by the scaling of the edge distances and because of this
////        consistent scaling of edge distances is not required. The main consideration for scaling edge distances for
////        use by the getOutline() functions should be the reduction of artefacts by improving interpolation accuracy.
////
////        The getInsetOutline() functions return a float3 consisting of { outline mask, outer fade in, inner fade out }.
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float rawOutline( in float3 edgesT )
{   //  triangle outline core logic
    return( min( edgesT * safe_rddw( edgesT ) ) );
}

float rawOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA )
{   //  general (concave/convex n-gon) outline core logic
    float3 ddxT = ddx( edgesT );
    float3 ddyT = ddy( edgesT );
    float3 ddxC = ddx( edgesC );
    float3 ddyC = ddy( edgesC );
    float3 ddxA = ddx( edgesA );
    float3 ddyA = ddy( edgesA );
    float3 maskV = saturate( sign( ( ddxC.xyz * ddyA.xyz ) - ( ddyC.xyz * ddxA.xyz ) ) );       //  vertex reciprocating clockwise/anti-clockwise clipping
    float3 maskN = saturate( sign( ( ddxC.zxy * ddyA.yzx ) - ( ddyC.zxy * ddxA.yzx ) ) );       //  neighbour reciprocating clockwise/anti-clockwise clipping
    float3 maskC = saturate( sign( ( ddxC.xyz * ddyT.yzx ) - ( ddyC.xyz * ddxT.yzx ) ) );       //  clockwise to clockwise neighbour clipping
    float3 maskA = saturate( sign( ( ddxT.zxy * ddyA.xyz ) - ( ddyT.zxy * ddxA.xyz ) ) );       //  anti-clockwise to anti-clockwise neighbour clipping
    float3 clipC = ( edgesC * safe_rsqrt( ( ddxC * ddxC ) + ( ddyC * ddyC ) ) );                //  anti-aliased clockwise half-spaces
    float3 clipA = ( edgesA * safe_rsqrt( ( ddxA * ddxA ) + ( ddyA * ddyA ) ) );                //  anti-aliased anti-clockwise half-spaces
    float3 drawC = max( clipC, ( clipA * maskV ) );                                             //  clip clockwise vertex half-spaces against their anti-clockwise partners
    float3 drawA = max( clipA, ( clipC * maskV ) );                                             //  clip anti-clockwise vertex half-spaces against their clockwise partners
    clipC *= maskC;                                                                             //  limit clockwise clipping to half-spaces intersecting the triangle
    clipA *= maskA;                                                                             //  limit anti-clockwise clipping to half-spaces intersecting the triangle
    drawC = max( drawC, max( clipC.yzx, ( clipA.zxy * saturate( maskC + maskN.yzx ) ) ) );      //  clip clockwise vertex half-spaces against neighbouring vertices
    drawA = max( drawA, max( clipA.zxy, ( clipC.yzx * saturate( maskA + maskN.zxy ) ) ) );      //  clip anti-clockwise vertex half-spaces against neighbouring vertices
    return( min( min( drawC, drawA ) ) );
}

float getOutline( in float3 edgesT )
{   //  triangle outline
    return( saturate( rawOutline( edgesT ) ) );
}

float getOutline( in float3 edgesT, in float width )
{   //  triangle outline with screen space pixel width
    return( saturate( rawOutline( edgesT ) + ( 1.0f - width ) ) );
}

float getOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA )
{   //  general (concave/convex n-gon) outline
    return( saturate( rawOutline( edgesT, edgesC, edgesA ) ) );
}

float getOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA, in float width )
{   //  general (concave/convex n-gon) outline with screen space pixel width
    return( saturate( rawOutline( edgesT, edgesC, edgesA ) + ( 1.0f - width ) ) );
}

float getWorldOutline( in float3 edgesT, in float width )
{   //  triangle outline with fixed world space width
    return( saturate( rawOutline( edgesT - width ) ) );
}

float getWorldOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA, in float width )
{   //  general (concave/convex n-gon) outline with fixed world space width
    return( saturate( rawOutline( edgesT, ( edgesC - width ), ( edgesA - width ) ) ) );
}

float3 getInsetOutline( in float3 edgesT, in float inset, in float width )
{   //  triangle inset outline with fixed world space inset and screen space pixel width
    float raw = rawOutline( edgesT - inset );
    return( saturate( float3( max( ( 1.0f - raw ), ( raw - width ) ), raw, ( raw - width ) ) ) );
}

float3 getInsetOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA, in float inset, in float width )
{   //  general (concave/convex n-gon) inset outline with fixed world space inset and screen space pixel width
    float raw = rawOutline( edgesT, ( edgesC - inset ), ( edgesA - inset ) );
    return( saturate( float3( max( ( 1.0f - raw ), ( raw - width ) ), raw, ( raw - width ) ) ) );
}

float3 getInsetOutline( in float3 edgesT, in float inset )
{   //  triangle inset outline with fixed world space inset
    return( getInsetOutline( edgesT, inset, 1.0f ) );
}

float3 getInsetOutline( in float3 edgesT, in float3 edgesC, in float3 edgesA, in float inset )
{   //  general (concave/convex n-gon) inset outline with fixed world space inset
    return( getInsetOutline( edgesT, edgesC, edgesA, 1.0f ) );
}

