#ifndef __STRUCTS_HLSL_INCLUDED__
#define __STRUCTS_HLSL_INCLUDED__

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    shared structures
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

struct Target
{   //  render target or viewport description
    fvec4       dimensions;     //  { width, height, (1.0f/width), (1.0f/height) }
    fvec4       clip_to_uv;     //  { ((width-1)/(width*2)), ((1-height)/(height*2)), 0.5f, 0.5f }
    fvec4       uv_to_clip;     //  { ((width*2)/(width-1)), ((height*2)/(1-height)), ((0-width)/(width-1)), ((0-height)/(1-height)) }
};

struct Entity
{   //  standard entity transform
    fvec4       scale;          //  { x, y, z, unused }
    fvec4       rotate;         //  { i, j, k, r (unit quaternion) }
    fvec4       locate;         //  { x, y, z, unused }
};

struct Camera
{
    fvec4       rotate;         //  { i, j, k, r (unit quaternion) }
    fvec4       locate;         //  { x, y, z, unused }
    fmat44      project;
    fmat44      unproject;
};

struct Scene
{
    Target      target;
    Camera      camera;
};

struct VDisplay
{
    fvec4       ranges;         //  { (width-1)*0.5, (height-1)*0.5, -1/(fadeFar-fadeNear), fadeFar/(fadeFar-fadeNear) }
    fvec4       alphas;         //  { background alpha, background brightness, foreground alpha, foreground brightness }
};

struct VDrawing
{
    fvec4       config;         //  { brightness, alpha mul, alpha add, unused }
};

//  the object contains 2 transforms:
//      transform raw model space geometry to object space using pscale, nscale and offset
//      transform object space to lighting space using rotate and locate (lighting space is world space)
struct Object
{
    fvec4       pscale;         //  position scaling to local space { x, y, z, clip plane 1 scale }
    fvec4       nscale;         //  normal scaling to local space { 1/x, 1/y, 1/z, clip plane 2 scale }
    fvec4       offset;         //  offset to local space { x, y, z, clip plane 2 offset }
    fvec4       rotate;         //  rotate to world space { i, j, k, r (unit quaternion) }
    fvec4       locate;         //  scale and translate to world space { x, y, z, scale }
    fvec4       eyepos;         //  world space eye position for reflection and specular effects { x, y, z, inset scale }
};

//  the viewer contains 2 transforms:
//      transform object space to view space using rotate and locate
//      transform view space to clip space using mhclip
//
//  the viewer also contains 2 view space clipping planes
//
//  NOTE: rotate and translate is the complete transform to view space including the object transform, any portal transforms and the camera transform
struct Viewer
{
    fvec4       rotate;         //  rotate to view space { i, j, k, r (unit quaternion) }
    fvec4       locate;         //  scale and translate to view space { x, y, z, scale }
    fvec4       plane1;         //  view space clip plane 1
    fvec4       plane2;         //  view space clip plane 2
    fmat44      mhclip;         //  homogenous clip space transform (projection matrix)
};

struct TrimAB
{
    fvec4       param1;         //  inputs to parameter a { scale t, scale r, scale (1-r), offset }
    fvec4       param2;         //  inputs to parameter b { scale t, scale r, scale (1-r), offset }
    fvec4       mixer1;         //  mixing of parameters { scale a, scale b, scale ab, offset }
    fvec4       mixer2;         //  mixing of parameters { scale a, scale b, scale ab, offset }
    fvec4       colour;         //  target colour for blend
};

struct Lintel
{
    TrimAB      effects[ 2 ];   //  effects
    fvec4       masking;        //  effect masking { -ve mul fx0, +ve mul fx0, -ve mul fx1, +ve mul fx1, }
};

