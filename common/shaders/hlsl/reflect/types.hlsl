////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    types.hlsl
////
////    standard types shared between the shaders and the run-time
////
////    this file should be included by the shaders
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    start of include guard
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#ifndef __TYPES_HLSL_INCLUDED__
#define __TYPES_HLSL_INCLUDED__

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    alignment notes:
////
////        constant buffers:
////
////            alignment is to 16 bytes
////            types which use less than 16 bytes are padded
////            fmat33 is aligned to 16 bytes and occupies 48 bytes (each row is padded to 16 bytes)
////
////        structured and byte buffers:
////
////            alignment is to a combination of 4 and 16 bytes
////            types are aligned to 4 bytes and packed into blocks of 16 bytes
////            if packing would cause a type to cross a 16 byte boundary it is moved to the next 16 byte boundary
////            fmat33 is aligned to 16 bytes and occupies 36 bytes
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    shared types
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

/// vectors
typedef float2  fvec2;
typedef float3  fvec3;
typedef float4  fvec4;

/// integer vectors
typedef int2    ivec2;
typedef int3    ivec3;
typedef int4    ivec4;

/// unsigned integer vectors
typedef uint2   uvec2;
typedef uint3   uvec3;
typedef uint4   uvec4;

/// matrices
typedef row_major float3x3  fmat33;
typedef row_major float2x4  fmat42;
typedef row_major float3x4  fmat43;
typedef row_major float4x4  fmat44;

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    end of include guard
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#endif  //  #ifndef __TYPES_HLSL_INCLUDED__

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    end of file
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
