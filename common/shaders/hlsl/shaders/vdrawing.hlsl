////    pre-requisite includes
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../libs/config.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    configuration defines
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#define STD_ENTITY_ENABLE   ENABLED
#define VTX_ENABLE_INTPOS   ENABLED
#define VTX_ENABLE_DRAW2D   ENABLED
#define VTX_ENABLE_COLOUR   ENABLED

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    includes
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../libs/std_entity.hlsl"
#include "../libs/std_vertex.hlsl"
#include "../libs/scene.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    instance constant buffer
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

cbuffer cb_vdrawing
{
    VDrawing    vconfig;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    shader code
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Interpolators vs( in Vertex vsin )
{
    Interpolators vsout;
    std_transformVertex( scene.camera, std_getEntity(), vsin, vsout );
    return( vsout );
}

float4 ps( in Interpolators psin ) : SV_Target0
{
    float alpha = ( ( psin.colour.a * vconfig.config.y ) + vconfig.config.z );
    float brightness = ( vconfig.config.x * alpha );
    return( float4( ( psin.colour.rgb * brightness ), alpha ) );
}

