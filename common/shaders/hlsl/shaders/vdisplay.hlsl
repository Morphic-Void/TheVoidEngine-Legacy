#define STD_ENTITY_ENABLE   ENABLED
#define VTX_ENABLE_INTPOS   ENABLED
#define VTX_ENABLE_DRAW2D   ENABLED
#define VTX_ENABLE_COLOUR   ENABLED
#define VTX_ENABLE_VIEWPOS  ENABLED
#define VTX_ENABLE_LOCALPOS ENABLED

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
