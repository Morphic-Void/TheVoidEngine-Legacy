#include "../libs/std_entity.hlsl"
#include "../libs/std_vertex.hlsl"
#include "../libs/scene.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    instance constant buffer
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

cbuffer cb_vdisplay
{
    VDisplay    vconfig;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    shader code
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Interpolators vs( in Vertex vsin )
{
    Interpolators vsout;
    std_transformVertex( scene.camera, std_getEntity(), vsin, vsout );
    return( vsout );
}

float4 ps( in Interpolators psin ) : SV_Target0
{
    float3 ranges = float3( ( vconfig.ranges.xy - abs( psin.localpos - vconfig.ranges.xy ) ), ( ( psin.viewpos.z * vconfig.ranges.z ) + vconfig.ranges.w ) );
    clip( ranges );
    float2 alphas = ( lerp( vconfig.alphas.xy, vconfig.alphas.zw, psin.colour.a ) * ranges.z );
    return( float4( ( psin.colour.rgb * alphas.y ), alphas.x ) );
}

