#define STD_ENTITY_ENABLE   ENABLED
#define VTX_ENABLE_COLOUR   ENABLED
#define VTX_ENABLE_ZBIAS    ENABLED

#ifdef ENABLE_LIGHTING
#define VTX_ENABLE_NORMAL   ENABLED
#endif

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    includes
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

#include "../libs/std_entity.hlsl"
#include "../libs/std_vertex.hlsl"
#include "../libs/scene.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    shader code
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Interpolators vs( in Vertex vsin )
{
    Interpolators vsout;
    std_transformVertex( scene.camera, std_getEntity(), vsin, vsout );
    return( vsout );
}

float4 ps( in Interpolators psin ) : SV_Target0
{
#ifdef ENABLE_LIGHTING
    float highlight = max( saturate( dot( normalize( psin.normal ), ( normalize( float3( 1.0f, 2.0f, -3.0f ) ) * 0.5f ) ) + 0.5f ), ( 1.0f / 256.0f ) );
    return( float4( saturate( psin.colour.rgb * highlight ), psin.colour.a ) );
#else
    return( psin.colour );
#endif
}

