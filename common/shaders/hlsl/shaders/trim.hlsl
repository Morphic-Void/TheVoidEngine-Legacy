#include "../libs/utils.hlsl"
#include "../libs/quaternions.hlsl"
#include "../reflect/types.hlsl"
#include "../reflect/structs.hlsl"

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    constant buffers
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

cbuffer cb_object
{
    Object  object;
};

cbuffer cb_viewer
{
    Viewer  viewer;
};

cbuffer cb_lintel
{
    Lintel  lintel;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    vertex structure
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

struct Vertex
{
    float3      position        :   POSITION;
    float3      offset          :   TEXCOORD0;
    float4      config          :   TEXCOORD1;
    float4      colour          :   COLOUR;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    interpolator structure
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

struct Interpolators
{
    float4      hclip           :   SV_Position;
    float2      cdist           :   SV_ClipDistance;
    float3      vs_pos          :   VS_POS;
    float3      ls_pos          :   LS_POS;
    float4      config          :   CONFIG;
    float4      colour          :   COLOUR;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    vertex shader
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Interpolators vs( in Vertex vsin )
{
    Interpolators vsout;

//  object space position
    float3 os_pos = ( ( vsin.position.xyz * object.pscale.xyz ) + object.offset.xyz + vsin.offset );

//  view space position
    float3 vs_pos = ( ( fastRotateVector( os_pos, viewer.rotate ) * viewer.locate.w ) + viewer.locate.xyz );

//  output homogenous clip space
    vsout.hclip = ( viewer.mhclip[ 3 ] + ( viewer.mhclip[ 2 ] * vs_pos.z ) + ( viewer.mhclip[ 1 ] * vs_pos.y ) + ( viewer.mhclip[ 0 ] * vs_pos.x ) );

//  output clipping distances
    vsout.cdist = float2( ( ( dot( vs_pos, viewer.plane1.xyz ) + viewer.plane1.w ) * object.pscale.w ), ( ( ( dot( vs_pos, viewer.plane2.xyz ) + viewer.plane2.w ) * object.nscale.w ) + object.offset.w ) );

//  output view space position
    vsout.vs_pos = vs_pos;

//  output lighting space position
    vsout.ls_pos = ( ( fastRotateVector( os_pos, object.rotate ) * object.locate.w ) + object.locate.xyz );

//  pass-through config
    vsout.config = vsin.config;

//  pass-through colour
    vsout.colour = vsin.colour;

    return( vsout );
}

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    pixel shader
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

float getTrimAB( in float4 config, in TrimAB effect, in float2 masking )
{
    float mask = saturate( ( abs( config.w ) * dot( masking, float2( ( 1.0f - config.w ), ( 1.0f + config.w ) ) ) ) );
    float3 params;
    params.x = ( dot( config.xyz, effect.param1.xyz ) + effect.param1.w );
    params.y = ( dot( config.xyz, effect.param2.xyz ) + effect.param2.w );
    params.xy = abs( ( frac( params.xy ) * 2.0f ) - 1.0f );
    params.z = ( params.x * params.y );
    return( saturate( ( dot( params, effect.mixer1.xyz ) + effect.mixer1.w ) * ( dot( params, effect.mixer2.xyz ) + effect.mixer2.w ) * mask ) );
}

float4 getLintel( in float4 config, in float4 colour )
{
    float e0 = getTrimAB( config, lintel.effects[ 0 ], lintel.masking.xy );
    float e1 = getTrimAB( config, lintel.effects[ 1 ], lintel.masking.zw );
    float e2 = ( e0 + e1 );
    e0 *= e0;
    e1 *= e1;
    float t0 = ( ( e0 - e1 ) / max( ( ( e0 + e1 ) * 2.0f ), ( 1.0f / 65536.0f ) ) );
    float t1 = ( ( e0 + e1 ) / max( e2, ( 1.0f / 65536.0f ) ) );
    return( ( colour * ( 1.0f - t1 ) ) + ( ( ( lintel.effects[ 0 ].colour * ( 0.5f - t0 ) ) + ( lintel.effects[ 1 ].colour * ( 0.5f + t0 ) ) ) * t1 ) );
}

float4 ps( in Interpolators psin ) : SV_Target0
{
    return( getLintel( psin.config, psin.colour ) );
}

