cbuffer cb_object
{
    Object  object;
};

cbuffer cb_viewer
{
    Viewer  viewer;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    vertex structure
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

struct Vertex
{
    float3      position        :   POSITION;
    float3      normal          :   NORMAL;
    float3      edgesT          :   TEXCOORD0;
    float3      edgesC          :   TEXCOORD1;
    float3      edgesA          :   TEXCOORD2;
    float4      colour          :   COLOUR;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    interpolator structure
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

struct Interpolators
{
    float4      hclip           :   SV_Position;
    float2      cdist           :   SV_ClipDistance;
    float3      vs_pos          :   VS_POS;
    float3      ls_pos          :   LS_POS;
    float3      ls_nrm          :   LS_NRM;
    float3      edgesT          :   EDGEST;
    float3      edgesC          :   EDGESC;
    float3      edgesA          :   EDGESA;
    float4      colour          :   COLOUR;
};

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////
////    vertex shader
////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Interpolators vs( in Vertex vsin )
{
    Interpolators vsout;

//  object space position
    float3 os_pos = ( ( vsin.position.xyz * object.pscale.xyz ) + object.offset.xyz );

//  view space position
    float3 vs_pos = ( ( fastRotateVector( os_pos, viewer.rotate ) * viewer.locate.w ) + viewer.locate.xyz );

//  output homogenous clip space
    vsout.hclip = ( viewer.mhclip[ 3 ] + ( viewer.mhclip[ 2 ] * vs_pos.z ) + ( viewer.mhclip[ 1 ] * vs_pos.y ) + ( viewer.mhclip[ 0 ] * vs_pos.x ) );

//  output clipping distances
    vsout.cdist = float2( ( ( dot( vs_pos, viewer.plane1.xyz ) + viewer.plane1.w ) * object.pscale.w ), ( ( ( dot( vs_pos, viewer.plane2.xyz ) + viewer.plane2.w ) * object.nscale.w ) + object.offset.w ) );

//  output view space position
    vsout.vs_pos = vs_pos;

//  output lighting space position
    vsout.ls_pos = ( ( fastRotateVector( os_pos, object.rotate ) * object.locate.w ) + object.locate.xyz );

//  output lighting space normal
    vsout.ls_nrm = fastRotateVector( normalize( vsin.normal.xyz * object.nscale.xyz ), object.rotate );

//  pass through edge deltas
    vsout.edgesT = vsin.edgesT;
    vsout.edgesC = vsin.edgesC;
    vsout.edgesA = vsin.edgesA;

//  pass-through colour
    vsout.colour = vsin.colour;

    return( vsout );
}

