float calcFadeT( in float3 pos )
{
    float fade_dist = 32.0f;
    float clip_dist = 128.0f;
    return( ( ( rlen( pos ) * clip_dist ) - 1.0f ) * ( fade_dist / ( clip_dist - fade_dist ) ) );
}

float fadeOutlining( in float3 pos, in float3 edgesO, in float3 edgesC, in float3 edgesA )
{
    float max_width = 8.0f;
    float t = calcFadeT( pos );
    float s = min( t, ( ( t * max_width ) / ( t + max_width - 1.0f ) ) );
    return( ( ( getOutline( edgesO, edgesC, edgesA, 2.0f ) - 1.0f ) * saturate( t * t ) ) + 1.0f );
}

